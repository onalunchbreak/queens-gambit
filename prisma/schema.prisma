// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A finished chess game session on Harmon's Gambit.
model GameSession {
  id          String   @id @default(cuid())
  // Player display name (entered on the entry screen).
  playerName  String
  // "w" or "b" — the color the human played.
  playerColor String
  // AI difficulty: novice | club | master
  difficulty  String
  // Final result category: "player_win" | "ai_win" | "draw"
  result      String
  // Who won: "player" | "ai" | "draw"
  winner      String
  // Human-readable result, e.g. "White wins by checkmate"
  resultLabel String
  // Number of half-moves (ply) played.
  moveCount   Int
  // Wall-clock duration in seconds from first move to game end.
  durationSec Int
  // Full SAN move list joined by spaces, for later study.
  moves       String
  // Final FEN of the game.
  finalFen    String
  startedAt   DateTime
  finishedAt  DateTime @default(now())

  @@index([playerName])
  @@index([difficulty])
  @@index([winner])
  @@index([finishedAt])
}
